# ============================================================================
# Dujiao-Next Environment Variables
# ============================================================================
# Copy this file to .env and modify the values.
# 复制此文件为 .env 并修改值。
#
# IMPORTANT: Never commit .env to version control!
# ============================================================================

# ── Redis Password (PCI-DSS 8.2.1) ─────────────────────────
# Generate with: openssl rand -base64 32
DJ_REDIS_PASSWORD=CHANGE_ME_GENERATE_RANDOM_PASSWORD

# ── Admin Credentials (first startup only) ──────────────────
# Leave DJ_DEFAULT_ADMIN_PASSWORD empty to auto-generate a random password
DJ_DEFAULT_ADMIN_USERNAME=admin
DJ_DEFAULT_ADMIN_PASSWORD=

# ── Port Configuration ──────────────────────────────────────
# User frontend (via nginx)
DJ_HTTP_PORT=80
DJ_HTTPS_PORT=443
# Admin frontend (via nginx)
DJ_ADMIN_PORT=81
