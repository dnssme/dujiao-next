# ============================================================================
# Dujiao-Next API — 环境变量 / Environment Variables
# ============================================================================
# 复制为 .env 并修改值。不要将 .env 提交到版本控制。
# Copy to .env and edit. Never commit .env to version control.
# ============================================================================

# ── 管理员凭据（仅首次启动生效）──────────────────────────────
# 留空 DJ_DEFAULT_ADMIN_PASSWORD 会自动生成随机密码并打印到日志
DJ_DEFAULT_ADMIN_USERNAME=admin
DJ_DEFAULT_ADMIN_PASSWORD=
